# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# base de datos SQLite
*.db
*.db-journal
prisma/*.db

# documentos personales
/docs

# datos de despliegue
/data

# plantilla original (solo referencia local, no se despliega)
/Hoja De Vida

# configuración local de herramientas
/.claude

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
